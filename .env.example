# Copy to .env and fill in values before deploying.
# NEVER commit .env to git.

# ── Deployer ──────────────────────────────────────────────────────────────────
# Wallet private key (0x-prefixed)
PRIVATE_KEY=0x

# Basescan API key for contract verification (https://basescan.org/myapikey)
BASESCAN_API_KEY=

# Optional: override default public RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Mint configuration ────────────────────────────────────────────────────────
# Price per token in ETH (default: 0.01 if not set)
MINT_PRICE_ETH=0.01

# IPFS base URI for metadata — set AFTER running upload-metadata.js
# Format: ipfs://<CID>/   (trailing slash required)
# deploy.cjs will fail if this is not set.
BASE_URI=

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Get keys at https://app.pinata.cloud/keys
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Local directories containing your images and metadata JSON files
# upload-images.js reads from IMAGES_DIR
# upload-metadata.js and update-metadata-uris.js read from METADATA_DIR
IMAGES_DIR=/Users/anthony/Desktop/PNP
METADATA_DIR=/Users/anthony/Desktop/PNP/metadata

# ── Development ───────────────────────────────────────────────────────────────
# Set to "true" to print gas estimates during tests
REPORT_GAS=false
